{
  "manifest_version": 3,
  "name": "Bilibili 屏蔽插件合集",
  "version": "2.9",
  "description": "屏蔽 Bilibili 多余推荐内容，并支持锁定策略、专注重定向和深浅主题",
  "permissions": ["storage", "scripting", "tabs", "alarms"],
  "host_permissions": ["*://*.bilibili.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["redirect.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.bilibili.com/video/*"],
      "js": ["playerOverlay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://search.bilibili.com/*"],
      "js": ["searchOverlay.js"],
      "css": ["searchOverlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "controlPanel.html",
    "default_icon": "extensionIcon.png"
  },
  "options_page": "options.html",
  "icons": {
    "128": "extensionIcon.png"
  }
}
